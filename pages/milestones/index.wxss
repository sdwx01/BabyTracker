.milestone-hero {
  padding: 30rpx;
}

.hero-button {
  margin-top: 22rpx;
}

.milestone-item {
  margin-top: 22rpx;
  padding: 28rpx;
}

.milestone-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.milestone-head-actions {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 12rpx;
}

.milestone-title {
  font-size: 32rpx;
  font-weight: 700;
}

.milestone-date {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #8e7b69;
}

.milestone-note {
  margin-top: 18rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #564438;
}

.milestone-delete {
  font-size: 24rpx;
  color: #c96543;
}

.media-scroll {
  width: 100%;
  margin-top: 22rpx;
  white-space: nowrap;
}

.media-track {
  display: inline-flex;
  gap: 16rpx;
}

.media-item,
.editor-media-item {
  position: relative;
}

.media-thumb,
.editor-media-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 20rpx;
  background: #f2e4d6;
}

.video-thumb {
  position: relative;
}

.video-tag {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(47, 36, 29, 0.64);
  color: #fff;
  font-size: 22rpx;
}

.milestone-textarea {
  min-height: 160rpx;
}

.media-section {
  margin-top: 18rpx;
}

.editor-media-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.editor-media-remove {
  position: absolute;
  left: 10rpx;
  bottom: 10rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(51, 38, 29, 0.62);
  color: #fff;
  font-size: 22rpx;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.sheet-close {
  font-size: 26rpx;
  color: #8a7564;
}
