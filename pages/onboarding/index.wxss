.onboarding-shell {
  padding-top: 40rpx;
}

.onboarding-hero,
.form-card {
  padding: 32rpx 28rpx;
}

.hero-eyebrow {
  font-size: 24rpx;
  letter-spacing: 6rpx;
  color: #a88467;
}

.hero-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  line-height: 1.2;
  font-weight: 700;
}

.hero-subtitle {
  margin-top: 18rpx;
  font-size: 27rpx;
  line-height: 1.7;
  color: #866f5f;
}

.landing-stack {
  margin-top: 24rpx;
}

.landing-button {
  margin-top: 18rpx;
}

.form-card {
  margin-top: 24rpx;
}

.form-group {
  margin-top: 24rpx;
}

.chooser-button {
  width: 100%;
}

.submit-button {
  margin-top: 28rpx;
}

.ghost-button {
  margin-top: 16rpx;
  border: none;
  background: transparent;
  color: #8c725f;
  font-size: 26rpx;
}
