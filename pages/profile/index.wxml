<view class="page-shell">
  <view class="hero-card profile-hero">
    <view class="avatar-badge">{{baby.avatarText}}</view>
    <view class="profile-name">{{baby.nickname}}</view>
    <view class="profile-meta">出生于 {{baby.birthDate}} · {{genderLabel}}</view>
    <button class="secondary-button edit-button" bindtap="editNickname">修改昵称</button>
  </view>

  <view class="surface-card section-card">
    <view class="section-title">数据同步</view>
    <view class="section-subtitle">{{dataSource.statusText}}</view>
    <view class="sync-row">
      <view>
        <view class="sync-label">优先使用云开发</view>
        <view class="sync-meta">{{dataSource.syncMetaText}}</view>
      </view>
      <switch checked="{{dataSource.preferCloudSync}}" color="#d46e4b" bindchange="onCloudPreferenceChange" />
    </view>
    <view class="sync-hint">{{dataSource.hintText}}</view>
    <view wx:if="{{dataSource.lastError}}" class="sync-error">{{dataSource.lastError}}</view>
    <view class="sync-actions">
      <button class="secondary-button sync-button" bindtap="bootstrapCloud">初始化云端</button>
      <button class="secondary-button sync-button" bindtap="pullFromCloud">拉取云端</button>
      <button class="secondary-button sync-button" bindtap="pushToCloud">上传本地</button>
    </view>
  </view>

  <view class="surface-card section-card">
    <view class="section-title">家庭协作</view>
    <view class="section-subtitle">邀请另一位照护者加入后，会共享同一份宝宝记录</view>
    <view wx:if="{{hasCaregivers}}" class="caregiver-list">
      <view class="caregiver-item" wx:for="{{caregivers}}" wx:key="id">
        <view>
          <view class="caregiver-name">{{item.name}}</view>
          <view class="caregiver-role">{{item.role}}</view>
        </view>
        <view>
          <view wx:if="{{item.isOwner}}" class="pill owner-pill">创建者</view>
          <view wx:else class="pill">已加入</view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-state">还没有照护者信息。</view>
    <view class="invite-box">
      <view class="invite-label">邀请口令</view>
      <view class="invite-code">{{inviteCodeText}}</view>
    </view>
    <button class="secondary-button family-button" bindtap="updateMyRole">设置我的身份</button>
    <button class="secondary-button family-button" bindtap="joinFamily">输入邀请码加入家庭</button>
  </view>

  <view class="surface-card section-card">
    <view class="section-title">产品原则</view>
    <view class="guideline-list">
      <view class="guideline-item">高频记录尽量两步完成。</view>
      <view class="guideline-item">统计只展示真正有用的信息。</view>
      <view class="guideline-item">重要照片和视频集中在“第一次”。</view>
      <view class="guideline-item">服务层已预留微信云开发接入位点。</view>
    </view>
  </view>
</view>
