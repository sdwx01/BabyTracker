<view class="page-shell">
  <view class="hero-card profile-hero">
    <view class="avatar-badge">{{avatarText}}</view>
    <view class="profile-name">{{profileTitle}}</view>
    <view class="profile-meta">{{profileMeta}}</view>
    <button class="secondary-button family-button" bindtap="editBaby">编辑宝宝资料</button>
  </view>

  <view class="surface-card section-card">
    <view class="section-title">云端同步</view>
    <view class="section-subtitle">{{dataSource.statusText}}</view>
    <view class="sync-row">
      <view>
        <view class="sync-label">自动同步记录</view>
        <view class="sync-meta">{{dataSource.syncMetaText}}</view>
      </view>
      <switch checked="{{dataSource.preferCloudSync}}" color="#d46e4b" bindchange="onCloudPreferenceChange" />
    </view>
    <view class="sync-hint">{{dataSource.hintText}}</view>
    <view wx:if="{{dataSource.lastError}}" class="sync-error">{{dataSource.lastError}}</view>
  </view>

  <view class="surface-card section-card">
    <view class="section-title">家庭共享</view>
    <view class="section-subtitle">把邀请码发给家人，对方输入后就能共享同一份记录。</view>
    <view class="invite-box">
      <view class="invite-label">邀请码</view>
      <view class="invite-code">{{inviteCodeText}}</view>
    </view>
    <button class="secondary-button family-button" bindtap="copyInviteCode">复制邀请码</button>
    <button class="secondary-button family-button" bindtap="joinFamily">输入邀请码加入家庭</button>
  </view>
</view>

<view wx:if="{{showBabyEditor}}">
  <view class="sheet-mask" bindtap="closeBabyEditor"></view>
  <view class="sheet-panel">
    <view class="sheet-header">
      <view>
        <view class="section-title">编辑宝宝资料</view>
        <view class="section-subtitle">一次修改昵称、出生日期和性别。</view>
      </view>
      <text class="sheet-close" bindtap="closeBabyEditor">关闭</text>
    </view>

    <view class="editor-group">
      <view class="field-label">宝宝昵称</view>
      <input class="field-input" placeholder="如 糯米 / 小满" value="{{editorNickname}}" data-field="editorNickname" bindinput="onEditorInputChange" />
    </view>

    <view class="editor-group">
      <view class="field-label">出生日期</view>
      <picker mode="date" value="{{editorBirthDate}}" bindchange="onEditorBirthDateChange">
        <view class="field-picker">{{editorBirthDateText}}</view>
      </picker>
    </view>

    <view class="editor-group">
      <view class="field-label">性别</view>
      <picker mode="selector" range="{{genderOptions}}" value="{{editorGenderIndex}}" bindchange="onEditorGenderChange">
        <view class="field-picker">{{editorGenderText}}</view>
      </picker>
    </view>

    <button class="primary-button save-button" bindtap="submitBabyEditor">保存资料</button>
  </view>
</view>
