.profile-hero,
.section-card {
  padding: 28rpx;
}

.avatar-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #f3c89f 0%, #de8158 100%);
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
}

.profile-name {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 700;
}

.profile-meta {
  margin-top: 12rpx;
  font-size: 25rpx;
  color: #8f7968;
  line-height: 1.6;
}

.section-card {
  margin-top: 22rpx;
}

.sync-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-top: 22rpx;
}

.sync-label {
  font-size: 28rpx;
  font-weight: 700;
}

.sync-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8d7866;
  line-height: 1.5;
}

.sync-hint {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff6ed;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b6555;
}

.sync-error {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: #fff0eb;
  font-size: 24rpx;
  line-height: 1.5;
  color: #b55d43;
}

.invite-box {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #fff6ed;
}

.invite-label {
  font-size: 22rpx;
  color: #947f6c;
}

.invite-code {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.family-button {
  margin-top: 22rpx;
}

.sheet-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.sheet-close {
  font-size: 26rpx;
  color: #8d7866;
}

.editor-group {
  margin-top: 22rpx;
}

.save-button {
  margin-top: 28rpx;
}
