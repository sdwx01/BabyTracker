<view class="page-shell">
  <view class="surface-card section-card">
    <view class="section-title">邀请码</view>
    <view class="section-subtitle">把邀请码发给家人，对方输入后就能共享同一份记录。</view>
    <view class="invite-box">
      <view class="invite-code">{{inviteCodeText}}</view>
    </view>
    <button class="secondary-button action-button" bindtap="copyInviteCode">复制邀请码</button>
    <button class="secondary-button action-button" bindtap="joinFamily">输入邀请码加入家庭</button>
  </view>

  <view class="surface-card section-card">
    <view class="section-title">家庭成员</view>
    <view class="section-subtitle">这里只展示当前已经加入共享记录的成员。</view>
    <view wx:if="{{hasMembers}}" class="member-list">
      <view class="member-item" wx:for="{{members}}" wx:key="id">
        <view>
          <view class="member-name">{{item.name}}</view>
          <view class="member-role">{{item.role}}</view>
        </view>
        <view wx:if="{{item.isOwner}}" class="pill owner-pill">创建者</view>
        <view wx:else class="pill">已加入</view>
      </view>
    </view>
    <view wx:else class="empty-state">开启云端同步并邀请家人后，成员会显示在这里。</view>
  </view>
</view>
