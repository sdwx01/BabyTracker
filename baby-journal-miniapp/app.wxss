.page {
  min-height: 100vh;
  background: #f8fafc;
  color: #1f2937;
  padding: 24rpx;
  box-sizing: border-box;
}

.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 10rpx 30rpx rgba(15, 23, 42, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.muted {
  color: #6b7280;
}

.primary-btn {
  background: #ff7a59;
  color: #fff;
  border-radius: 999rpx;
  font-size: 28rpx;
  line-height: 1.2;
  padding: 20rpx 24rpx;
}

.ghost-btn {
  background: #fff3ef;
  color: #ff7a59;
  border-radius: 999rpx;
  font-size: 26rpx;
  padding: 16rpx 20rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  background: #f3f4f6;
  color: #374151;
}

.chip.active {
  background: #ffede8;
  color: #ff5a36;
}

.field {
  margin-bottom: 20rpx;
}

.label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.input,
.textarea {
  width: 100%;
  background: #f8fafc;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
  font-size: 28rpx;
}

.textarea {
  min-height: 160rpx;
}

.row {
  display: flex;
  gap: 16rpx;
}

.row > view,
.row > button {
  flex: 1;
}

.empty {
  text-align: center;
  color: #94a3b8;
  padding: 50rpx 20rpx;
}
