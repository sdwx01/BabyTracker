<view class="page">
  <view class="card">
    <view class="section-title">今天快速记录</view>
    <view class="muted" style="margin-bottom: 20rpx;">尽量一屏完成，单手也能点。</view>
    <view>
      <block wx:for="{{recordTypes}}" wx:key="key">
        <view class="chip {{activeType === item.key ? 'active' : ''}}" data-type="{{item.key}}" bindtap="chooseType">{{item.label}}</view>
      </block>
    </view>
  </view>

  <view class="card">
    <view class="field">
      <text class="label">数量/时长（可选）</text>
      <input class="input" placeholder="如 120ml、2片、30分钟" value="{{amount}}" bindinput="onAmountInput" />
    </view>
    <view class="field">
      <text class="label">备注（可选）</text>
      <textarea class="textarea" placeholder="比如吃奶状态、药名、便便情况、第一次翻身..." value="{{note}}" bindinput="onNoteInput"></textarea>
    </view>
    <button class="primary-btn" bindtap="quickSave">保存这次记录</button>
  </view>

  <view class="card">
    <view class="section-title">今日概览</view>
    <view class="row" style="margin-bottom: 16rpx;">
      <view>
        <view class="muted">今日记录</view>
        <view style="font-size: 40rpx; font-weight: 700;">{{stats.today}}</view>
      </view>
      <view>
        <view class="muted">累计记录</view>
        <view style="font-size: 40rpx; font-weight: 700;">{{stats.total}}</view>
      </view>
    </view>
    <view class="muted">最近可以去“时间线”里查看完整记录。</view>
  </view>
</view>
