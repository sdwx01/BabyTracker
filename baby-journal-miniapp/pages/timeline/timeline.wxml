<view class="page">
  <view class="card">
    <view class="section-title">时间线</view>
    <view class="muted">按时间倒序展示所有记录。</view>
  </view>

  <block wx:if="{{records.length}}">
    <block wx:for="{{records}}" wx:key="id">
      <view class="card">
        <view class="row" style="justify-content: space-between; align-items: center;">
          <view style="font-weight: 600;">{{item.typeLabel}}</view>
          <view class="muted">{{item.displayTime}}</view>
        </view>
        <view wx:if="{{item.amount}}" style="margin-top: 12rpx;">数量/时长：{{item.amount}}</view>
        <view wx:if="{{item.note}}" class="muted" style="margin-top: 12rpx;">{{item.note}}</view>
      </view>
    </block>
  </block>

  <view wx:else class="card empty">还没有记录，先去“记录”页记第一条吧。</view>
</view>
